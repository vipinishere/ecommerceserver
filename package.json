{
  "name": "ecommerceserver",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "husky",
    "postinstall": "prisma generate",
    "prebuild": "rimraf dist && prisma generate",
    "build": "nest build",
    "format": "prettier --write . --plugin=@prettier/plugin-pug",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint . --fix",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint",
    "test": "jest --detectOpenHandles --onlyChanged",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --detectOpenHandles --onlyChanged --config ./test/jest-e2e.json",
    "monitoring": "docker compose -f monitoring/docker-compose.yaml up -d",
    "monitoring:stop": "docker compose -f monitoring/docker-compose.yaml down",
    "prod:db": "docker compose up -d postgres redis mongo",
    "prod:db:stop": "docker compose stop postgres redis mongo",
    "dev:db": "docker compose -f docker-compose.dev.yaml up -d postgres redis",
    "dev:db:stop": "docker compose -f docker-compose.dev.yaml stop postgres redis",
    "pgadmin": "docker compose -f docker-compose.dev.yaml up -d pgadmin",
    "dev": "docker compose -f docker-compose.dev.yaml up --build --attach nestjs-app",
    "dev:stop": "docker compose -f docker-compose.dev.yaml down",
    "prod": "docker compose up -d --build nestjs-app",
    "prod:stop": "docker compose stop nestjs-app",
    "db:studio": "prisma studio",
    "db:init": "npm run db:schema:push && npm run db:schema:constraints && npm run db:seed",
    "db:seed": "prisma db seed",
    "db:seed:only": "prisma db seed -- --seed-only",
    "db:schema:constraints": "ts-node prisma/constraints.ts",
    "db:schema:constraints:only": "ts-node prisma/constraints.ts -- --table",
    "db:schema:push": "prisma db push",
    "db:schema:format": "prisma format",
    "db:schema:validate": "prisma validate",
    "db:client:generate": "prisma generate",
    "db:migration:create": "prisma migrate dev --create-only",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset --skip-seed",
    "postdb:migrate:reset": "npm run db:init",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "engines": {
    "node": "^24"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.3",
    "@prisma/client": "^6.19.0",
    "axios": "^1.13.2",
    "bullmq": "^5.65.1",
    "cache-manager": "^7.2.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "lodash": "^4.17.21",
    "nanoid": "^3.3.7",
    "nodemailer": "^7.0.11",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prom-client": "^15.1.3",
    "pug": "^3.0.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.2",
    "rxjs": "^7.8.2",
    "winston": "^3.18.3",
    "winston-mongodb": "^7.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@prettier/plugin-pug": "^3.4.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pug": "^2.0.10",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prisma": "^6.19.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@Common": "<rootDir>/common/index",
      "^@Config": "<rootDir>/configs/index"
    }
  },
  "lint-staged": {
    "**/*.js|ts": [
      "eslint --cache --fix"
    ],
    "**/*": [
      "prettier --write . --plugin=@prettier/plugin-pug"
    ],
    "prisma/schema.prisma": [
      "prisma format"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
