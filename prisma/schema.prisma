// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum AdminRole {
  SUPER_ADMIN @map("super_admin")
  ADMIN       @map("admin")

  @@map("admin_role")
}

enum SellerStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("seller_status")
}

enum AdminStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("admin_status")
}

enum UserStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")

  @@map("user_status")
}

enum PrimeType {
  MONTHLY @map("monthly")
  YEARLY  @map("yearly")

  @@map("prime_type")
}

enum TransactionType {
  CREDIT @map("credit")
  DEBIT  @map("debit")

  @@map("transaction_type")
}

enum WalletReferenceType {
  DEPOSIT  @map("deposit")
  ORDER    @map("order")
  REFUND   @map("refund")
  RECHARGE @map("recharge")
  CASHBACK @map("cashback")

  @@map("wallet_reference_type")
}

enum WalletTransactionStatus {
  PENDING   @map("pending")
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@map("wallet_transaction_status")
}

enum ReturnPolicyType {
  NO_RETURN         @map("no_return")
  REPLACEMENT_ONLY  @map("replacement_only")
  RETURN_AND_REFUND @map("return_and_refund")

  @@map("return_policy_type")
}

enum ShipmentStatus {
  PROCESSING       @map("processing")
  SHIPPED          @map("shipped")
  OUT_FOR_DELIVERY @map("out_for_delivery")
  DELIVERED        @map("delivered")
  FAILED           @map("failed")

  @@map("shipment_status")
}

enum OrderStatus {
  PENDING   @map("pending")
  PACKED    @map("packed")
  SHIPPED   @map("shipped")
  DELIVERED @map("delivered")
  CANCELLED @map("cancelled")
  RETURNED  @map("returned")

  @@map("order_status")
}

enum PaymentTypeForWallet {
  CARD @map("card")
  UPI  @map("upi")

  @@map("payment_type_for_wallet")
}

enum PaymentType {
  COD    @map("cod")
  CARD   @map("card")
  UPI    @map("upi")
  WALLET @map("wallet")

  @@map("payment_type")
}

enum TransactionStatus {
  PENDING @map("pending")
  SUCCESS @map("success")
  FAILED  @map("failed")

  @@map("transaction_status")
}

enum DataType {
  TEXT    @map("text")
  NUMBER  @map("number")
  BOOLEAN @map("boolean")

  @@map("data_type")
}

model User {
  id                String     @id @default(uuid())
  firstname         String     @db.VarChar(100)
  lastname          String     @db.VarChar(100)
  email             String     @unique @db.VarChar(150)
  profileImage      String?    @map("profile_image")
  dialCode          String     @map("dial_code") @db.VarChar(3)
  primaryNumber     String     @map("primary_number") @db.VarChar(15)
  alternativeNumber String?    @map("alternative_number") @db.VarChar(15)
  isPrimeMember     Boolean    @default(false) @map("is_prime_member")
  primeType         PrimeType? @map("prime_type")
  primeExpiry       DateTime?  @map("prime_expiry")
  rewardPoints      Int        @default(0) @map("reward_points")
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  meta              UserMeta?

  addresses          Address[]
  cartItems          CartItem[]
  wishlists          Wishlist[]
  orders             Order[]
  reviews            Review[]
  walletAccount      WalletAccount?
  cards              CardDetail[]
  paymentMethods     PaymentMethod[]
  watchHistory       WatchHistory[]
  transactionDetails TransactionDetail[]
  userSettings       UserSetting[]

  @@map("user")
}

model UserMeta {
  id           String  @id @default(uuid())
  passwordSalt String? @map("password_salt")
  passwordHash String? @map("password_hash")
  refreshToken String? @map("refresh_token")
  userId       String  @unique @map("user_id")
  user         User    @relation(fields: [userId], references: [id])

  @@map("user_meta")
}

model Admin {
  id           String      @id @default(uuid())
  firstname    String      @db.VarChar(100)
  lastname     String      @db.VarChar(100)
  email        String      @unique @db.VarChar(150)
  profileImage String?     @map("profile_image")
  role         AdminRole   @default(ADMIN)
  status       AdminStatus @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  meta         AdminMeta?

  @@map("admin")
}

model AdminMeta {
  id           String  @id @default(uuid())
  passwordSalt String? @map("password_salt")
  passwordHash String? @map("password_hash")
  refreshToken String? @map("refresh_token")
  adminId      String  @unique @map("admin_id")
  admin        Admin   @relation(fields: [adminId], references: [id])

  @@map("admin_meta")
}

// DONE

model Address {
  id                     String   @id @default(uuid())
  userId                 String   @map("user_id")
  name                   String   @db.VarChar(100)
  dialCode               String   @map("dial_code") @db.VarChar(3)
  phoneNumber            String   @map("phone_number") @db.VarChar(15)
  alternativePhoneNumber String?  @map("alternative_phone_number") @db.VarChar(15)
  addressLine1           String   @map("address_line1")
  addressLine2           String?  @map("address_line2")
  city                   String   @db.VarChar(100)
  state                  String   @db.VarChar(100)
  postalCode             String   @map("postal_code") @db.VarChar(10)
  country                String   @db.VarChar(100)
  isDefault              Boolean  @default(false) @map("is_default")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("address")
}

model Seller {
  id           String       @id @default(uuid())
  businessName String       @map("business_name") @db.VarChar(150)
  contactEmail String       @unique @map("contact_email") @db.VarChar(150)
  dialCode     String       @map("dial_code") @db.VarChar(3)
  contactPhone String       @map("contact_phone") @db.VarChar(15)
  profileImage String?      @map("profile_image")
  isVerified   Boolean      @default(false) @map("is_verified")
  status       SellerStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  meta         SellerMeta?

  products   Product[]
  orderItems OrderItem[]

  @@map("seller")
}

model SellerMeta {
  id           String  @id @default(uuid())
  passwordSalt String? @map("password_salt")
  passwordHash String? @map("password_hash")
  refreshToken String? @map("refresh_token")
  sellerId     String  @unique @map("seller_id")
  seller       Seller  @relation(fields: [sellerId], references: [id])

  @@map("seller_meta")
}

// DONE

model WalletAccount {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  currentBalance Decimal  @default(0) @map("current_balance") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]

  @@map("wallet_account")
}

// DONE

model WalletTransaction {
  id                      String                  @id @default(uuid())
  walletId                String                  @map("wallet_id")
  transactionType         TransactionType         @map("transaction_type")
  referenceType           WalletReferenceType     @map("reference_type")
  referenceId             String?                 @map("reference_id")
  amount                  Decimal                 @db.Decimal(12, 2)
  balanceAfterTransaction Decimal                 @map("balance_after_transaction") @db.Decimal(12, 2)
  status                  WalletTransactionStatus
  createdAt               DateTime                @default(now()) @map("created_at")

  wallet WalletAccount @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([createdAt])
  @@map("wallet_transaction")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String   @default("My Wishlist") @db.VarChar(100)
  isPublic  Boolean  @default(false) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User           @relation(fields: [userId], references: [id])
  items WishlistItem[]

  @@index([userId])
  @@map("wishlist")
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlistId String   @map("wishlist_id")
  productId  String   @map("product_id")
  variantId  String?  @map("variant_id")
  note       String?  @db.VarChar(200)
  addedAt    DateTime @default(now()) @map("added_at")

  wishlist Wishlist        @relation(fields: [wishlistId], references: [id])
  product  Product         @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@map("wishlist_item")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  variantId String   @map("variant_id")
  quantity  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id])
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([userId, variantId])
  @@index([userId])
  @@index([productId])
  @@map("cart_item")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(150)
  description String?  @db.VarChar(500)
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("category_parent", fields: [parentId], references: [id])
  children Category[] @relation("category_parent")

  products           Product[]
  categoryAttributes CategoryAttribute[]

  @@index([parentId])
  @@map("category")
}

model Product {
  id              String   @id @default(uuid())
  internalName    String   @map("internal_name") @db.VarChar(200)
  seoTitle        String?  @map("seo_title") @db.VarChar(200)
  description     String?  @db.Text
  categoryId      String   @map("category_id")
  sellerId        String   @map("seller_id")
  mrp             Decimal  @db.Decimal(10, 2)
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  sku             String?  @db.VarChar(100)

  giftOptionAvailable Boolean @default(false) @map("gift_option_available")
  packagingType       String? @map("packaging_type") @db.VarChar(100)

  isFreeDelivery  Boolean @default(false) @map("is_free_delivery")
  isPayOnDelivery Boolean @default(false) @map("is_pay_on_delivery")

  returnPolicyId String? @map("return_policy_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category     Category      @relation(fields: [categoryId], references: [id])
  seller       Seller        @relation(fields: [sellerId], references: [id])
  returnPolicy ReturnPolicy? @relation(fields: [returnPolicyId], references: [id])

  images                 ProductImage[]
  variants               ProductVariant[]
  reviews                Review[]
  specifications         ProductSpecification[]
  priceHistory           ProductPriceHistory[]
  wishlistItems          WishlistItem[]
  cartItems              CartItem[]
  productRatingSummaries ProductRatingSummary[]
  watchHistories         WatchHistory[]
  orderItems             OrderItem[]

  @@index([categoryId])
  @@index([sellerId])
  @@map("product")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  imageUrl  String   @map("image_url")
  altText   String?  @map("alt_text") @db.VarChar(200)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("product_image")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  sku           String   @unique @db.VarChar(100)
  variantName   String?  @map("variant_name") @db.VarChar(100)
  color         String?  @db.VarChar(50)
  size          String?  @db.VarChar(50)
  storage       String?  @db.VarChar(50)
  mrp           Decimal  @db.Decimal(10, 2)
  sellingPrice  Decimal  @map("selling_price") @db.Decimal(10, 2)
  stockQuantity Int      @default(0) @map("stock_quantity")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  product       Product        @relation(fields: [productId], references: [id])
  wishlistItems WishlistItem[]
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@index([productId])
  @@map("product_variant")
}

model ProductPriceHistory {
  id              String    @id @default(uuid())
  productId       String    @map("product_id")
  mrp             Decimal   @db.Decimal(12, 2)
  discountPercent Decimal   @map("discount_percent") @db.Decimal(5, 2)
  sellingPrice    Decimal   @map("selling_price") @db.Decimal(12, 2)
  validFrom       DateTime  @map("valid_from")
  validTo         DateTime? @map("valid_to")
  createdAt       DateTime  @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, validFrom])
  @@map("product_price_history")
}

model SpecificationGroup {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(300)
  createdAt   DateTime @default(now()) @map("created_at")

  attributes SpecificationAttribute[]

  @@map("specification_group")
}

model CategoryAttribute {
  id          String   @id @default(uuid())
  categoryId  String   @map("category_id")
  attributeId String   @map("attribute_id")
  isRequired  Boolean  @default(false) @map("is_required")
  createdAt   DateTime @default(now()) @map("created_at")

  category  Category               @relation(fields: [categoryId], references: [id])
  attribute SpecificationAttribute @relation(fields: [attributeId], references: [id])

  @@unique([categoryId, attributeId])
  @@index([categoryId])
  @@map("category_attribute")
}

model SpecificationAttribute {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(300)
  unit        String?  @db.VarChar(50)
  dataType    DataType @map("data_type")
  createdAt   DateTime @default(now()) @map("created_at")

  group                 SpecificationGroup     @relation(fields: [groupId], references: [id])
  categoryAttributes    CategoryAttribute[]
  productSpecifications ProductSpecification[]

  @@index([groupId])
  @@map("specification_attribute")
}

model ProductSpecification {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  attributeId  String   @map("attribute_id")
  valueText    String?  @map("value_text") @db.Text
  valueNumber  Decimal? @map("value_number") @db.Decimal(10, 4)
  valueBoolean Boolean? @map("value_boolean")
  createdAt    DateTime @default(now()) @map("created_at")

  product   Product                @relation(fields: [productId], references: [id])
  attribute SpecificationAttribute @relation(fields: [attributeId], references: [id])

  @@unique([productId, attributeId])
  @@index([productId])
  @@map("product_specification")
}

model Order {
  id               String      @id @default(uuid())
  orderNumber      String      @unique @map("order_number")
  userId           String      @map("user_id")
  orderStatus      OrderStatus @default(PENDING) @map("order_status")
  totalItemsAmount Decimal     @map("total_items_amount") @db.Decimal(10, 2)
  shippingCharge   Decimal     @map("shipping_charge") @db.Decimal(10, 2)
  codFee           Decimal?    @map("cod_fee") @db.Decimal(10, 2)
  discountAmount   Decimal?    @map("discount_amount") @db.Decimal(10, 2)
  grandTotal       Decimal     @map("grand_total") @db.Decimal(10, 2)
  placedAt         DateTime?   @map("placed_at")
  paidAt           DateTime?   @map("paid_at")
  deliveredAt      DateTime?   @map("delivered_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id])
  items     OrderItem[]
  shipments Shipment[]
  payments  OrderPayment[]

  @@index([userId])
  @@map("order")
}

model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String   @map("order_id")
  productId           String   @map("product_id")
  sellerId            String   @map("seller_id")
  variantId           String?  @map("variant_id")
  productNameSnapshot String   @map("product_name_snapshot") @db.VarChar(200)
  productSkuSnapshot  String   @map("product_sku_snapshot") @db.VarChar(100)
  quantity            Int
  unitPriceAtPurchase Decimal  @map("unit_price_at_purchase") @db.Decimal(10, 2)
  totalPrice          Decimal  @map("total_price") @db.Decimal(10, 2)
  createdAt           DateTime @default(now()) @map("created_at")

  order   Order           @relation(fields: [orderId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  seller  Seller          @relation(fields: [sellerId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_item")
}

model Shipment {
  id                String         @id @default(uuid())
  orderId           String         @map("order_id")
  trackingNumber    String         @unique @map("tracking_number")
  carrier           String         @db.VarChar(100)
  status            ShipmentStatus
  shippedAt         DateTime?      @map("shipped_at")
  estimatedDelivery DateTime?      @map("estimated_delivery")
  deliveredAt       DateTime?      @map("delivered_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  order          Order                   @relation(fields: [orderId], references: [id])
  trackingEvents ShipmentTrackingEvent[]

  @@index([orderId])
  @@map("shipment")
}

model ShipmentToken {
  id        String   @id @default(uuid())
  token     String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("shipment_token")
}

model ShipmentTrackingEvent {
  id          String   @id @default(uuid())
  shipmentId  String   @map("shipment_id")
  eventStatus String   @map("event_status") @db.VarChar(100)
  location    String   @db.VarChar(200)
  eventTime   DateTime @map("event_time")
  createdAt   DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId])
  @@map("shipment_tracking_event")
}

model Review {
  id                 String   @id @default(uuid())
  productId          String   @map("product_id")
  userId             String   @map("user_id")
  orderId            String?  @map("order_id")
  rating             Int
  title              String?  @db.VarChar(100)
  body               String?  @db.Text
  isVerifiedPurchase Boolean  @default(false) @map("is_verified_purchase")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  product Product       @relation(fields: [productId], references: [id])
  user    User          @relation(fields: [userId], references: [id])
  images  ReviewImage[]
  videos  ReviewVideo[]

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@map("review")
}

model ReviewImage {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id])

  @@index([reviewId])
  @@map("review_image")
}

model ReviewVideo {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  videoUrl  String   @map("video_url")
  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id])

  @@index([reviewId])
  @@map("review_video")
}

model ProductRatingSummary {
  productId     String   @id @map("product_id")
  rating1Count  Int      @map("rating1_count")
  rating2Count  Int      @map("rating2_count")
  rating3Count  Int      @map("rating3_count")
  rating4Count  Int      @map("rating4_count")
  rating5Count  Int      @map("rating5_count")
  averageRating Decimal  @map("average_rating") @db.Decimal(3, 2)
  totalReviews  Int      @map("total_reviews")
  updatedAt     DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([averageRating])
  @@map("product_rating_summary")
}

model WatchHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  viewedAt  DateTime @default(now()) @map("viewed_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("watch_history")
}

model CardDetail {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  // cardLast4 and cardBrand come from payment provider (Stripe/Razorpay) — never from user input
  cardLast4     String   @map("card_last4") @db.VarChar(4)
  cardBrand     String   @map("card_brand") @db.VarChar(50)
  providerToken String   @map("provider_token")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("card_detail")
}

model PaymentMethod {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  paymentType PaymentType @map("payment_type")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user          User                @relation(fields: [userId], references: [id])
  transactions  TransactionDetail[]
  orderPayments OrderPayment[]

  @@index([userId])
  @@map("payment_method")
}

model TransactionDetail {
  id                String            @id @default(uuid())
  userId            String            @map("user_id")
  paymentMethodId   String            @map("payment_method_id")
  transactionId     String            @unique @map("transaction_id")
  transactionRefId  String?           @map("transaction_ref_id")
  transactionStatus TransactionStatus @map("transaction_status")
  razorpayOrderId   String?           @map("razorpay_order_id")
  razorpayPaymentId String?           @map("razorpay_payment_id")
  razorpaySignature String?           @map("razorpay_signature")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id])
  paymentMethod PaymentMethod  @relation(fields: [paymentMethodId], references: [id])
  orderPayments OrderPayment[]

  @@index([userId])
  @@map("transaction_detail")
}

model OrderPayment {
  id                  String    @id @default(uuid())
  orderId             String    @map("order_id")
  paymentMethodId     String    @map("payment_method_id")
  transactionDetailId String    @map("transaction_detail_id")
  amount              Decimal   @db.Decimal(10, 2)
  paidAt              DateTime? @map("paid_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  order             Order             @relation(fields: [orderId], references: [id])
  paymentMethod     PaymentMethod     @relation(fields: [paymentMethodId], references: [id])
  transactionDetail TransactionDetail @relation(fields: [transactionDetailId], references: [id])

  @@index([orderId])
  @@index([paymentMethodId])
  @@map("order_payment")
}

model ReturnPolicy {
  id                        String           @id @default(uuid())
  name                      String           @db.VarChar(100)
  type                      ReturnPolicyType
  returnDays                Int              @map("return_days")
  description               String?          @db.VarChar(500)
  requiresOriginalPackaging Boolean          @default(false) @map("requires_original_packaging")
  requiresAllAccessories    Boolean          @default(false) @map("requires_all_accessories")
  isActive                  Boolean          @default(true) @map("is_active")
  createdAt                 DateTime         @default(now()) @map("created_at")
  updatedAt                 DateTime         @updatedAt @map("updated_at")

  products Product[]

  @@map("return_policy")
}

enum OtpTransport {
  Email  @map("email")
  Mobile @map("mobile")

  @@map("otp_transport")
}

model Otp {
  code             String
  attempt          Int          @default(1) @db.SmallInt
  lastSentAt       DateTime     @default(now()) @map("last_sent_at")
  retries          Int          @default(0) @db.SmallInt
  transport        OtpTransport
  target           String
  lastCodeVerified Boolean      @default(false) @map("last_code_verified")
  blocked          Boolean      @default(false)

  @@unique([transport, target])
  @@map("otp")
}

enum SettingType {
  Binary       @map("binary")
  MultiSelect  @map("multi_select")
  SingleSelect @map("single_select")

  @@map("setting_type")
}

enum SettingContext {
  User   @map("user")
  System @map("System")

  @@map("setting_context")
}

model Setting {
  id               Int             @id @default(autoincrement())
  mappedTo         String          @map("mapped_to")
  text             String          @default("")
  description      String          @default("")
  type             SettingType
  context          SettingContext
  default          Json
  isDefinedOptions Boolean         @map("is_defined_options")
  subSettings      Setting[]       @relation("SubSettings")
  dependsOn        Setting?        @relation("SubSettings", fields: [parentId], references: [id])
  parentId         Int?            @map("parent_id")
  options          SettingOption[]
  userSettings     UserSetting[]
  systemSettings   SystemSetting[]

  @@unique([context, mappedTo])
  @@map("setting")
}

model SettingOption {
  id        Int     @id @default(autoincrement())
  text      String  @default("")
  value     String
  setting   Setting @relation(fields: [settingId], references: [id])
  settingId Int     @map("setting_id")

  @@unique([settingId, value])
  @@map("setting_option")
}

model UserSetting {
  selection Json
  user      User    @relation(fields: [userId], references: [id])
  userId    String  @map("user_id")
  setting   Setting @relation(fields: [settingId], references: [id])
  settingId Int     @map("setting_id")

  @@id([userId, settingId])
  @@map("user_setting")
}

model SystemSetting {
  selection Json
  setting   Setting @relation(fields: [settingId], references: [id])
  settingId Int     @map("setting_id")

  @@id([settingId])
  @@map("system_setting")
}
